# Frontend -> Domain API shared secret (optional for local dev)
API_SHARED_SECRET=

# Optional Modal worker endpoint and key
NATURALCAD_CAD_WORKER_URL=
NATURALCAD_CAD_WORKER_API_KEY=

# Quotas
NATURALCAD_RATE_WINDOW_SECONDS=3600
NATURALCAD_GUEST_RUNS_PER_WINDOW=5
NATURALCAD_SIGNED_RUNS_PER_WINDOW=30

# OpenRouter model profiles (used by mode switcher metadata)
NATURALCAD_MODE_FAST=openai/gpt-4o-mini
NATURALCAD_MODE_BALANCED=google/gemini-2.5-pro
NATURALCAD_MODE_QUALITY=anthropic/claude-sonnet-4
